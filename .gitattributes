# Normalize all text files to LF in the repo and on checkout, so the codebase
# stays consistent across Windows/macOS/Linux and git stops rewriting endings.
# (This governs lookmd's own source — the app itself preserves the line endings
# of the user files it edits at runtime; that is handled in code, not here.)
* text=auto eol=lf

# Explicit text types
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Binaries — never touch
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff  binary
*.woff2 binary
